                  "key": "token",
                  "value": "{{super_admin_access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/users/admin/{{target_user_id}}/role?role=ROLE_USER",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "admin",
                "{{target_user_id}}",
                "role"
