    {
      "name": "3. Admin Operations (Admin/SuperAdmin Auth)",
      "item": [
        {
          "name": "Ban User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{admin_access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/users/admin/ban/{{target_user_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "admin",
                "ban",
                "{{target_user_id}}"
              ]
            }
          },
          "response": []
